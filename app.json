{
  "expo": {
    "name": "PolySpeaker",
    "slug": "polyspeaker",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "polyspeaker",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-speech-recognition",
      "expo-audio",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1B8FE0"
        }
      ],
      "./plugins/withReleaseSigning"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.polyspeaker.app",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "PolySpeaker uses speech recognition to transcribe what you say during pronunciation exercises and compare it to the expected phrase, so the app can score your pronunciation accuracy and show you where to improve.",
        "NSMicrophoneUsageDescription": "PolySpeaker uses the microphone to record your spoken responses during pronunciation exercises. For example, when practicing French, you will be prompted to say a word aloud and the app will analyze your pronunciation and provide instant feedback.",
        "NSPhotoLibraryUsageDescription": "Allow $(PRODUCT_NAME) to access your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "package": "com.polyspeaker.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f5a57c81-0d5d-4c15-9d12-988eaa6bd4ef"
      }
    },
    "owner": "raullimaos-organization"
  }
}
